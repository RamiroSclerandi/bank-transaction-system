# ─── Application ──
APP_NAME="Bank Transaction System"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ─── Database ──
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://bank_user:CHANGE_ME@localhost:5432/bank_transactions

# ─── AWS General ──
AWS_REGION=eu-west-1

# ─── AWS SQS ──
SQS_INTERNATIONAL_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/123456789012/international-payments

# ─── Internal Service Auth ──
# Shared secret for Lambda → FastAPI internal endpoints (use 32+ random bytes)
INTERNAL_SERVICE_API_KEY=CHANGE_ME_STRONG_RANDOM_SECRET

# Password used by scripts/seed_admin.py to create the first admin user.
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── CORS ──
# Comma-separated list of allowed origins
ALLOWED_ORIGINS_RAW=https://backoffice.bank.eu

# ─── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60

# ── AI Agent ──
GEMINI_API_KEY=CHANGE_ME_API_KEY

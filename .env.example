# ─── Application ────────────────────────────────────────────────────────────
APP_NAME="Bank Transaction System"
APP_VERSION="1.0.0"
DEBUG=true # Set to false in production
ENVIRONMENT=development # Change to "production" in production

# ─── Database ──
# docker-compose always overrides this with the internal db service URL.
# Set a real value here only when connecting to an external DB (e.g. RDS).
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_DB

# ─── AWS General ──
AWS_REGION=eu-west-1

# ─── AWS IAM credentials ──
# Set these only for local development when using real AWS services (SQS, etc.).
# In production (ECS), leave empty — boto3 uses the IAM Role of the task.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── AWS RDS ──
AWS_RDS_INSTANCE_IDENTIFIER=Change_Me_RDS_Instance_Identifier

# ─── AWS SQS ──
SQS_INTERNATIONAL_QUEUE_URL=Change_Me_SQS_Queue_URL

# ─── Internal Service Auth ──
# Shared secret for Lambda → FastAPI internal endpoints (use 32+ random bytes).
INTERNAL_SERVICE_API_KEY=CHANGE_ME_STRONG_RANDOM_SECRET

# ─── Card PAN hashing ──
# HMAC-SHA256 key used to hash card numbers. Generate with: openssl rand -hex 32
PAN_HMAC_KEY=CHANGE_ME_32_BYTE_HEX_KEY

# ─── Admin seeding ──
# Password used by scripts/seed_admin.py to create the first admin user.
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── CORS ──
# Comma-separated list of allowed origins for CORS.
ALLOWED_ORIGINS_RAW=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60
